<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:orientation="vertical" >

<LinearLayout 
    android:id="@+id/LinearLayout01"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    
    android:orientation="vertical"
    android:padding="10dip"
    android:scrollbars="vertical"
    android:paddingTop="20dp">

<LinearLayout 
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="1">

<EditText
    android:id="@+id/isearch"
    android:layout_width="190dip"
    android:layout_height="match_parent"
    android:singleLine="true"
    android:hint="தேடவேண்டிய சொல்(தமிழில்)"
    android:background="#b3fbb1"
    android:layout_weight="1.03">
</EditText>
<Button android:text="தேடுக" android:id="@+id/BSearch" android:padding="0dip"  android:layout_height="wrap_content" android:layout_width="60dip" android:layout_gravity="center"
    android:textStyle="bold"></Button>

</LinearLayout>

</LinearLayout>
</ScrollView>