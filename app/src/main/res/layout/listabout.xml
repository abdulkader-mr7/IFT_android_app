<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:orientation="vertical" 
    android:fadeScrollbars="false"
    android:paddingLeft="2dp" 
    android:paddingRight="2dp" 
    
    >

<LinearLayout 
    android:id="@+id/LinearLayout01"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:scrollbars="vertical" >
      <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tamil Font Size :-" 
        android:textStyle="bold"  />

   <SeekBar android:id="@+id/seek"
        android:layout_width="326dp"
        android:layout_height="wrap_content"
        android:max="36"
        android:progress="26"
        />

    <TextView android:id="@+id/progress"
       	android:layout_width="match_parent"
        android:layout_height="wrap_content" />
        
      <TextView
        android:id="@+id/textViewArabic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Arabic Font Size :-" 
        android:textStyle="bold"  />

   <SeekBar android:id="@+id/seekArabic"
        android:layout_width="314dp"
        android:layout_height="wrap_content"
        android:max="36"
        android:progress="26"
        />

    <TextView android:id="@+id/progressArabic"
       	android:layout_width="match_parent"
        android:layout_height="wrap_content" />
        
    
 

    <TextView
        android:id="@+id/textView1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show :-"
        android:textStyle="bold" />

    <Switch
        android:id="@+id/arabic_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Arabic Text       :" 
        android:textStyle="italic" />

    <Switch
        android:id="@+id/tamil_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tamil Translation :" 
        android:textStyle="italic" />
    

<TextView android:text="TEST" android:id="@+id/TextView02" android:layout_height="wrap_content" android:layout_width="fill_parent" android:textStyle="bold"></TextView>
<Button android:text="Rate this application" android:id="@+id/Button01" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center"></Button>

<TextView
    android:id="@+id/TextView05"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center"
    android:gravity="bottom"
    android:text="v3.4" >

</TextView>
</LinearLayout>
</ScrollView>
